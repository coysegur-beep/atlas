---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import WhatsAppFloat from '@/components/WhatsAppFloat.astro';
import { SITE } from '@/lib/config';
---

<BaseLayout
  title="Contacto y cotización"
  description={`Solicita una cotización personalizada de servicios de seguridad privada. Atendemos en Barranquilla y todo el Atlántico.`}
>
  <TopBar />
  <Header />

  <section class="bg-gradient-to-br from-atenas-azul-darker to-atenas-azul-deep text-white py-24">
    <div class="container-wide">
      <div class="section-eyebrow">Contacto</div>
      <h1 class="font-serif font-normal text-white max-w-[800px]" style="font-size: clamp(40px, 5vw, 64px); line-height: 1.1; letter-spacing: -0.02em;">
        Hablemos de tu <span class="italic text-atenas-dorado">necesidad de seguridad.</span>
      </h1>
      <p class="text-white/80 text-[19px] mt-6 max-w-[600px]">Cotización personalizada en menos de 24 horas.</p>
    </div>
  </section>

  <section class="py-20">
    <div class="container-wide">
      <div class="grid lg:grid-cols-2 gap-16">
        <div>
          <h2 class="font-serif text-atenas-azul-deep mb-8" style="font-size: 36px;">Información de contacto</h2>
          
          <div class="space-y-6">
            <a href={SITE.contact.phoneHref} class="flex gap-4 items-start group">
              <div class="w-12 h-12 bg-atenas-azul/10 rounded-md flex items-center justify-center flex-shrink-0 text-atenas-azul group-hover:bg-atenas-azul group-hover:text-white transition-colors">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
              </div>
              <div>
                <div class="text-[12px] text-text-muted uppercase tracking-wider font-semibold mb-1">Teléfono</div>
                <div class="text-[18px] text-atenas-azul-deep font-medium">{SITE.contact.phone}</div>
              </div>
            </a>

            <a href={SITE.social.whatsapp} target="_blank" rel="noopener" class="flex gap-4 items-start group">
              <div class="w-12 h-12 bg-[#25D366]/10 rounded-md flex items-center justify-center flex-shrink-0 text-[#25D366] group-hover:bg-[#25D366] group-hover:text-white transition-colors">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24z"/></svg>
              </div>
              <div>
                <div class="text-[12px] text-text-muted uppercase tracking-wider font-semibold mb-1">WhatsApp</div>
                <div class="text-[18px] text-atenas-azul-deep font-medium">{SITE.contact.whatsapp}</div>
              </div>
            </a>

            <a href={`mailto:${SITE.contact.email}`} class="flex gap-4 items-start group">
              <div class="w-12 h-12 bg-atenas-azul/10 rounded-md flex items-center justify-center flex-shrink-0 text-atenas-azul group-hover:bg-atenas-azul group-hover:text-white transition-colors">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <div class="text-[12px] text-text-muted uppercase tracking-wider font-semibold mb-1">Email</div>
                <div class="text-[18px] text-atenas-azul-deep font-medium">{SITE.contact.email}</div>
              </div>
            </a>

            <div class="flex gap-4 items-start">
              <div class="w-12 h-12 bg-atenas-dorado/10 rounded-md flex items-center justify-center flex-shrink-0 text-atenas-dorado">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <div class="text-[12px] text-text-muted uppercase tracking-wider font-semibold mb-1">Dirección</div>
                <div class="text-[18px] text-atenas-azul-deep font-medium">{SITE.contact.address.street}<br/>{SITE.contact.address.city}, {SITE.contact.address.region}</div>
              </div>
            </div>
          </div>
        </div>

        <div>
          <h2 class="font-serif text-atenas-azul-deep mb-8" style="font-size: 36px;">Solicita cotización</h2>
          
          <form class="space-y-5" method="post" action="/api/contact">
            <div>
              <label class="block text-[14px] font-semibold text-text mb-2">Nombre completo *</label>
              <input type="text" name="name" required class="w-full px-4 py-3 border border-text/15 rounded-md focus:border-atenas-azul focus:outline-none focus:ring-2 focus:ring-atenas-azul/10" />
            </div>
            <div>
              <label class="block text-[14px] font-semibold text-text mb-2">Empresa</label>
              <input type="text" name="company" class="w-full px-4 py-3 border border-text/15 rounded-md focus:border-atenas-azul focus:outline-none focus:ring-2 focus:ring-atenas-azul/10" />
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-[14px] font-semibold text-text mb-2">Teléfono *</label>
                <input type="tel" name="phone" required class="w-full px-4 py-3 border border-text/15 rounded-md focus:border-atenas-azul focus:outline-none focus:ring-2 focus:ring-atenas-azul/10" />
              </div>
              <div>
                <label class="block text-[14px] font-semibold text-text mb-2">Email *</label>
                <input type="email" name="email" required class="w-full px-4 py-3 border border-text/15 rounded-md focus:border-atenas-azul focus:outline-none focus:ring-2 focus:ring-atenas-azul/10" />
              </div>
            </div>
            <div>
              <label class="block text-[14px] font-semibold text-text mb-2">Servicio de interés *</label>
              <select name="service" required class="w-full px-4 py-3 border border-text/15 rounded-md focus:border-atenas-azul focus:outline-none focus:ring-2 focus:ring-atenas-azul/10">
                <option value="">Selecciona un servicio</option>
                <option value="vigilancia">Vigilancia</option>
                <option value="escoltas">Escoltas</option>
                <option value="medios-tecnologicos">Medios Tecnológicos</option>
                <option value="estudios-de-seguridad">Estudios de Seguridad</option>
                <option value="otro">Otro / Asesoría general</option>
              </select>
            </div>
            <div>
              <label class="block text-[14px] font-semibold text-text mb-2">Cuéntanos tu necesidad</label>
              <textarea name="message" rows="4" class="w-full px-4 py-3 border border-text/15 rounded-md focus:border-atenas-azul focus:outline-none focus:ring-2 focus:ring-atenas-azul/10 resize-y"></textarea>
            </div>
            <button type="submit" class="btn btn-secondary w-full justify-center">
              Enviar solicitud
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
            <p class="text-[12px] text-text-light text-center">Tus datos están protegidos según nuestra <a href="/legal/tratamiento-datos" class="text-atenas-azul underline">política de tratamiento de datos</a>.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>
