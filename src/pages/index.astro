---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import WhatsAppFloat from '@/components/WhatsAppFloat.astro';
import { SITE, SERVICIOS } from '@/lib/config';

const yearsOfExperience = new Date().getFullYear() - SITE.founded;

const stats = [
  { number: yearsOfExperience.toString(), label: 'Años de experiencia' },
  { number: '+450', label: 'Profesionales activos' },
  { number: '+200', label: 'Clientes corporativos' },
  { number: '24/7', label: 'Central de monitoreo' },
];

const whyAtenas = [
  {
    title: 'Experiencia comprobada',
    text: 'Casi tres décadas operando en el Atlántico. Hemos protegido empresas, propiedad horizontal y personas en los momentos que más importaban.',
  },
  {
    title: 'Tecnología propia',
    text: 'Departamento interno de innovación e informática. CCTV, GPS, control de acceso y monitoreo 24/7 desde nuestra central — todo bajo un mismo proveedor.',
  },
  {
    title: 'Cumplimiento normativo',
    text: 'Operamos con plena conformidad ante la Superintendencia de Vigilancia y Seguridad Privada. Auditorías y certificaciones vigentes.',
  },
];

const certifications = [
  { name: 'ISO 9001', desc: 'Calidad' },
  { name: 'ISO 14001', desc: 'Ambiental' },
  { name: 'BASC', desc: 'Comercio seguro' },
  { name: 'RUC', desc: 'Riesgos laborales' },
  { name: 'Supervigilancia', desc: 'Vigilada' },
];
---

<BaseLayout
  title="Empresa de seguridad privada en Barranquilla"
  description={`Atenas Seguridad Privada Ltda. — ${yearsOfExperience} años protegiendo Barranquilla. Vigilancia, escoltas, medios tecnológicos y estudios de seguridad en Atlántico, Colombia. Solicita cotización.`}
  schemaType="home"
>
  <TopBar />
  <Header />

  <!-- HERO -->
  <section class="relative bg-gradient-to-br from-atenas-azul-darker via-atenas-azul-deep to-[#0a2960] text-white pt-30 pb-35 overflow-hidden" style="padding-top: 120px; padding-bottom: 140px;">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle at 80% 20%, rgba(244, 161, 0, 0.08) 0%, transparent 40%), radial-gradient(circle at 10% 90%, rgba(29, 78, 216, 0.15) 0%, transparent 50%);"></div>
    
    <div class="container-wide relative z-10">
      <div class="max-w-[780px]">
        <div class="inline-flex items-center gap-2.5 bg-atenas-dorado/10 border border-atenas-dorado/30 text-atenas-dorado px-4 py-2 rounded-full text-[13px] font-medium uppercase tracking-[0.05em] mb-8">
          <span class="w-1.5 h-1.5 bg-atenas-dorado rounded-full animate-pulse-soft"></span>
          Empresa certificada · Supervigilancia
        </div>
        
        <h1 class="font-serif font-normal leading-[1.05] tracking-[-0.02em] mb-7" style="font-size: clamp(40px, 5.5vw, 76px);">
          <span class="italic text-atenas-dorado font-medium">{yearsOfExperience} años</span> protegiendo<br/>
          lo que más <span class="border-b-[3px] border-atenas-dorado pb-1">importa</span><br/>
          en {SITE.contact.address.city}
        </h1>
        
        <p class="text-[19px] leading-[1.6] text-white/[0.78] mb-11 max-w-[600px]">
          Servicios de seguridad privada, escoltas, medios tecnológicos y estudios de seguridad para empresas, propiedad horizontal y personas en {SITE.contact.address.region}, {SITE.contact.address.country}.
        </p>
        
        <div class="flex gap-4 flex-wrap items-center">
          <a href="/contacto" class="btn btn-primary">
            Solicitar cotización
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/servicios" class="btn btn-ghost">Conocer nuestros servicios</a>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <div class="container-wide">
    <div class="bg-white border border-text/[0.08] rounded-md grid grid-cols-2 md:grid-cols-4 -mt-15 relative z-20" style="margin-top: -60px; box-shadow: 0 20px 60px rgba(10, 31, 77, 0.08);">
      {stats.map((stat, i) => (
        <div class:list={["py-9 px-8 text-center", { "border-r border-text/[0.08]": i < stats.length - 1 }]}>
          <div class="font-serif text-[52px] font-medium text-atenas-azul leading-none mb-2 tracking-[-0.02em]">{stat.number}</div>
          <div class="text-[13px] text-text-muted uppercase tracking-[0.08em] font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- SOBRE NOSOTROS -->
  <section class="py-30" style="padding: 120px 0;">
    <div class="container-wide">
      <div class="grid lg:grid-cols-2 gap-20 items-center">
        <div class="relative aspect-[4/5] bg-gradient-to-br from-atenas-azul-deep to-atenas-azul rounded-md overflow-hidden">
          <div class="absolute bottom-8 left-8 right-8 text-white/85 text-[13px] uppercase tracking-[0.1em] border-t border-atenas-dorado/40 pt-4">
            Sobre Atenas
            <span class="block font-serif text-[28px] text-white normal-case tracking-[-0.01em] mt-2 leading-[1.2]">
              Seguridad construida sobre experiencia, tecnología y confianza.
            </span>
          </div>
        </div>
        
        <div>
          <div class="section-eyebrow">Quiénes somos</div>
          <h2 class="font-serif font-normal mb-6 text-atenas-azul-deep" style="font-size: clamp(34px, 4vw, 52px); line-height: 1.1; letter-spacing: -0.02em; max-width: 720px;">
            Una tradición de <span class="italic text-atenas-azul">protección institucional</span> en el Caribe colombiano.
          </h2>
          <p class="text-text-muted text-[16.5px] leading-[1.75] mb-5">
            En <strong>{SITE.name}</strong> ofrecemos servicios de seguridad confiables y de calidad en {SITE.contact.address.city}, {SITE.contact.address.region}. Con {yearsOfExperience} años en el sector, nuestro equipo de profesionales altamente capacitados está comprometido en brindar soluciones efectivas y personalizadas para proteger a nuestros clientes y sus activos.
          </p>
          <p class="text-text-muted text-[16.5px] leading-[1.75]">
            Nos mantenemos a la vanguardia de las tecnologías y tendencias en seguridad, garantizando la tranquilidad y satisfacción de nuestros clientes en todo momento.
          </p>
          
          <div class="mt-9 grid gap-5">
            <div class="flex gap-4 p-5 border-l-[3px] border-atenas-dorado bg-atenas-dorado/[0.04]">
              <svg class="w-8 h-8 text-atenas-dorado flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <div>
                <h4 class="text-[16px] mb-1 text-atenas-azul-deep font-semibold font-sans">Personal certificado</h4>
                <p class="text-[14px] text-text-muted">Capacitación conforme a Supervigilancia y estándares internacionales.</p>
              </div>
            </div>
            <div class="flex gap-4 p-5 border-l-[3px] border-atenas-dorado bg-atenas-dorado/[0.04]">
              <svg class="w-8 h-8 text-atenas-dorado flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div>
                <h4 class="text-[16px] mb-1 text-atenas-azul-deep font-semibold font-sans">Respuesta inmediata</h4>
                <p class="text-[14px] text-text-muted">Equipo de reacción y comunicación permanente con redes de apoyo de la Policía Nacional.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section id="servicios" class="bg-white border-y border-text/[0.08]" style="padding: 120px 0;">
    <div class="container-wide">
      <div class="grid md:grid-cols-[1fr_auto] items-end gap-10 mb-16">
        <div>
          <div class="section-eyebrow">Servicios</div>
          <h2 class="font-serif font-normal text-atenas-azul-deep" style="font-size: clamp(34px, 4vw, 52px); line-height: 1.1; letter-spacing: -0.02em;">
            Soluciones <span class="italic text-atenas-azul">conforme a tus necesidades</span> en seguridad.
          </h2>
        </div>
        <a href="/servicios" class="btn btn-outline">Ver todos los servicios</a>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {SERVICIOS.map((s, i) => (
          <a href={`/servicios/${s.slug}`} class="group bg-bg border border-text/[0.08] p-10 rounded-md transition-all duration-300 hover:-translate-y-1 hover:border-atenas-azul hover:shadow-[0_20px_40px_rgba(10,31,77,0.08)] relative overflow-hidden block">
            <div class="absolute top-0 left-0 w-0 h-[3px] bg-atenas-dorado transition-all duration-500 group-hover:w-full"></div>
            <div class="font-serif text-[14px] text-atenas-dorado italic tracking-[0.05em] mb-5">— Servicio {String(i + 1).padStart(2, '0')}</div>
            <div class="w-14 h-14 bg-atenas-azul text-white rounded-md flex items-center justify-center mb-6">
              {s.icono === 'shield' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
              {s.icono === 'users' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>}
              {s.icono === 'monitor' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>}
              {s.icono === 'file-search' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>}
            </div>
            <h3 class="font-serif font-medium text-[26px] text-atenas-azul-deep mb-3.5 tracking-[-0.01em]">{s.nombre}</h3>
            <p class="text-text-muted text-[15px] leading-[1.7] mb-6">{s.descripcionCorta}</p>
            <span class="text-atenas-azul text-[14px] font-semibold inline-flex items-center gap-2 transition-all group-hover:gap-3.5">
              Conocer más
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- POR QUE ATENAS -->
  <section class="bg-atenas-azul-darker text-white relative overflow-hidden" style="padding: 120px 0;">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 90% 10%, rgba(244, 161, 0, 0.06) 0%, transparent 40%);"></div>
    <div class="container-wide relative z-10">
      <div class="section-eyebrow">Por qué Atenas</div>
      <h2 class="font-serif font-normal text-white mb-0" style="font-size: clamp(34px, 4vw, 52px); line-height: 1.1; letter-spacing: -0.02em;">
        La tranquilidad de quien <span class="italic text-atenas-dorado">elige bien.</span>
      </h2>
      
      <div class="grid md:grid-cols-3 gap-8 mt-16">
        {whyAtenas.map((item, i) => (
          <div class="border-t border-atenas-dorado/30 pt-7">
            <div class="font-serif italic text-[14px] text-atenas-dorado mb-4 tracking-[0.05em]">— {String(i + 1).padStart(2, '0')}</div>
            <h4 class="font-serif font-medium text-[22px] mb-3 leading-[1.3]">{item.title}</h4>
            <p class="text-white/70 text-[15px] leading-[1.7]">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CERTIFICACIONES -->
  <section class="text-center" style="padding: 120px 0;">
    <div class="container-wide">
      <div class="section-eyebrow justify-center" style="justify-content: center;">Respaldo institucional</div>
      <h2 class="font-serif font-normal text-atenas-azul-deep mx-auto mb-6" style="font-size: clamp(34px, 4vw, 52px); line-height: 1.1; letter-spacing: -0.02em;">
        Nuestras certificaciones <span class="italic text-atenas-azul">nos respaldan.</span>
      </h2>
      <p class="text-[18px] text-text-muted max-w-[640px] mx-auto leading-[1.7] mb-16">
        Cumplimos con los más altos estándares de calidad, gestión ambiental y seguridad operacional reconocidos a nivel nacional e internacional.
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-6 max-w-[900px] mx-auto">
        {certifications.map((cert) => (
          <div class="aspect-square bg-white border border-text/[0.08] rounded-md flex flex-col items-center justify-center gap-2 p-4 hover:border-atenas-dorado hover:-translate-y-0.5 transition-all">
            <svg class="w-10 h-10 text-atenas-azul" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
            <span class="text-[11px] font-semibold uppercase tracking-[0.05em] text-text-muted">{cert.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="bg-gradient-to-br from-atenas-dorado to-[#d68900] text-atenas-azul-darker text-center relative overflow-hidden" style="padding: 100px 0;">
    <div class="container-wide relative z-10">
      <h2 class="font-serif font-normal text-atenas-azul-darker mx-auto mb-6 text-center" style="font-size: clamp(34px, 4vw, 52px); line-height: 1.1; letter-spacing: -0.02em;">
        ¿Listo para proteger lo que más importa?
      </h2>
      <p class="text-[18px] max-w-[600px] mx-auto mb-10 leading-[1.6]" style="color: rgba(10, 31, 77, 0.85);">
        Hablemos de tu necesidad de seguridad. Cotización personalizada en menos de 24 horas.
      </p>
      <a href="/contacto" class="btn bg-atenas-azul-darker text-white hover:bg-atenas-azul-deep">
        Solicitar cotización ahora
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>
